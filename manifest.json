{
  "manifest_version": 3,
  "name": "MailPilot AI – Gmail Writing Helper",
  "short_name": "MailPilot AI",
  "version": "1.0.0",
  "description": "Gmail AI writer that helps you compose, rewrite, and improve emails instantly. Boost productivity with smart email assistance.",
  "icons": {
    "16": "images/logo.png",
    "48": "images/logo.png",
    "128": "images/logo.png"
  },
  "action": {
    "default_icon": "images/logo.png",
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "utils/i18n.js",
        "content_scripts/send-guard.js",
        "content_scripts/compose-injector.js",
        "content_scripts/gmail-observer.js"
      ],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "mailpilotai@yourdomain.com",
      "strict_min_version": "109.0"
    }
  }
}